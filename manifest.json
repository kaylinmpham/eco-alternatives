{
  "manifest_version": 3,
  "name": "Eco Alternatives",
  "version": "0.1.0",
  "description": "Sustainability scores and secondhand alternatives while you shop.",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/detector.js",
        "src/content/index.js"
      ]
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Eco Alternatives"
  }
}
